model School {
  id            String   @id @default(uuid())
  name          String   @unique
  districtRange String   @default("[]") // 学区分区依据，JSON 数组
  address       String   @default("") // 学校地址
  notice        String   @default("") // 学校须知
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
