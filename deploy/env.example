# Copy this file to deploy/.env before running docker compose.

APP_PORT=3002
PORT=3000
TZ=Asia/Shanghai
PGTZ=Asia/Shanghai


# Use the PostgreSQL container name as host. The czedu container must join the
# same Docker network as that PostgreSQL container.
DATABASE_URL=postgresql://czedu:change-me@postgresql:5432/czedu?schema=public
POSTGRES_DOCKER_NETWORK=postgres_net
JWT_SECRET=change-this-to-a-long-random-secret

# Host directory used for uploaded files.
UPLOAD_HOST_DIR=/home/oss/xnczjyj

# Set to false after the database schema is initialized if you want startup to
# skip Prisma db push.
PRISMA_DB_PUSH=true
